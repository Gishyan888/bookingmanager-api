NODE_ENV=production
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=cpanel_db_user
DB_PASSWORD=replace-with-strong-db-password
DB_DATABASE=cpanel_db_name

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=1d

# Optional: first admin bootstrap (remove after first successful login)
# BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password
# BOOTSTRAP_ADMIN_NAME=Administrator

# Optional: email delivery
# MAIL_HOST=smtp.yourprovider.com
# MAIL_PORT=587
# MAIL_USER=your-smtp-user
# MAIL_PASS=your-smtp-password
# MAIL_FROM=no-reply@yourdomain.com
