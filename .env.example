PORT=3000
NODE_ENV=development

# MySQL (match docker-compose defaults or your server)
DB_HOST=localhost
# Use 3307 when connecting to MySQL from docker-compose.yml (host maps 3307 -> container 3306)
DB_PORT=3307
DB_USERNAME=bookingmanager
DB_PASSWORD=bookingmanager
DB_DATABASE=bookingmanager

# Auth
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=1d

# First deploy only: when the `users` table is empty, create one admin (then remove or rotate password).
# BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
# BOOTSTRAP_ADMIN_NAME=Administrator
